---
import { copy, REGISTER_URL, WA_URL } from '../../content/copy';
---

<section class="bg-coal section-pad relative overflow-hidden">
  <div class="aurora aurora-dark" aria-hidden="true">
    <div class="aurora-blob aurora-blob-1"></div>
    <div class="aurora-blob aurora-blob-2"></div>
    <div class="aurora-blob aurora-blob-3"></div>
  </div>
  <div class="max-w-3xl mx-auto text-center relative" style="z-index: 1;">
    <h2 class="reveal display text-inv text-4xl sm:text-5xl">{copy.cta_final.title}</h2>
    <p class="reveal text-inv-2 text-lg mt-5 max-w-xl mx-auto">{copy.cta_final.sub}</p>
    <div class="reveal flex flex-col sm:flex-row items-center justify-center gap-3.5 mt-9">
      <a href={REGISTER_URL} data-meta="lead" data-meta-name="CTA final - Probar gratis" class="btn btn-primary w-full sm:w-auto !text-[1.0625rem] !px-7 !py-4">{copy.cta_final.cta}</a>
      <a href={WA_URL} target="_blank" rel="noopener" data-meta="contact" data-meta-name="CTA final - WhatsApp" class="btn btn-ghost-dark w-full sm:w-auto !text-[1.0625rem] !px-7 !py-4">Hablar por WhatsApp</a>
    </div>
  </div>
</section>
