---
import { copy } from '../../content/copy';

const icons: Record<string, string> = {
  'Revendedores de iPhone':
    'M7 3.5h10a1.5 1.5 0 0 1 1.5 1.5v14a1.5 1.5 0 0 1-1.5 1.5H7A1.5 1.5 0 0 1 5.5 19V5A1.5 1.5 0 0 1 7 3.5Zm3 14.5h4',
  'Tiendas multi-marca':
    'M4 9.5 5.5 4h13L20 9.5M4 9.5V20h16V9.5M4 9.5h16M9.5 20v-6h5v6',
  'Servicio técnico':
    'M14.5 6.5a4 4 0 0 0-5.3 4.9L4 16.6V20h3.4l5.2-5.2a4 4 0 0 0 4.9-5.3l-2.6 2.6-2.4-2.4 2-2.2Z',
};
---

<section class="bg-paper-2 section-pad">
  <div class="max-w-6xl mx-auto">
    <div class="reveal max-w-2xl">
      <p class="kicker mb-3">{copy.para_quien.kicker}</p>
      <h2 class="display text-4xl sm:text-5xl">{copy.para_quien.title}</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6 mt-12" data-stagger>
      {copy.para_quien.cards.map((card) => (
        <div class="reveal bg-paper border border-line rounded-2xl p-8">
          <div class="w-11 h-11 rounded-xl bg-brand-soft flex items-center justify-center mb-5">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2952E3" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={icons[card.title] ?? icons['Tiendas multi-marca']} />
            </svg>
          </div>
          <h3 class="display text-xl font-bold">{card.title}</h3>
          <p class="text-text-2 mt-3 leading-relaxed text-[0.9375rem]">{card.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
