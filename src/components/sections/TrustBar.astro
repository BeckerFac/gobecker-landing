---
import { copy } from '../../content/copy';
---

<section class="bg-paper border-b border-line py-10 px-6">
  <div class="max-w-6xl mx-auto">
    <p class="reveal text-center font-mono text-[0.8125rem] tracking-wide text-text-3 uppercase mb-7">{copy.social_proof.title}</p>
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-4" data-stagger>
      {copy.social_proof.items.map((item) => (
        <li class="reveal flex items-start gap-2.5 text-[0.9375rem] text-text-2 leading-snug">
          <svg class="check-ok mt-1" width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13.5 4.5 6.4 11.6 2.5 7.7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {item}
        </li>
      ))}
    </ul>
  </div>
</section>
