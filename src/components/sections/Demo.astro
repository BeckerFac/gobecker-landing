---
import { copy } from '../../content/copy';

// VIDEOS: grabados de la app real (demo TecnoCenter) con Playwright.
// Para reemplazarlos por versiones grabadas a mano: pisar public/videos/recorrida.mp4 y venta.mp4.
---

<section id="producto" class="bg-card border-y border-line section-pad">
  <div class="max-w-6xl mx-auto">
    <div class="reveal max-w-2xl">
      <p class="kicker mb-3">{copy.demo.kicker}</p>
      <h2 class="display text-4xl sm:text-5xl">{copy.demo.title}</h2>
      <p class="text-text-2 text-lg mt-4">{copy.demo.sub}</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-6 mt-12" data-stagger>
      {copy.demo.videos.map((video) => (
        <figure class="reveal">
          <div class="video-slot frame-light" data-video-src={video.src} role="button" tabindex="0" aria-label={`Reproducir video: ${video.title}`}>
            <img src={video.poster} alt={video.title} width="1920" height="1080" loading="lazy" />
            <div class="play-badge">
              <div class="play-circle">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="#fff" aria-hidden="true"><path d="M8 5.5v13l11-6.5-11-6.5Z"/></svg>
              </div>
            </div>
          </div>
          <figcaption class="text-text-2 text-[0.9375rem] mt-3 font-medium">{video.title}</figcaption>
        </figure>
      ))}
    </div>

    <div class="grid sm:grid-cols-2 gap-6 mt-10" data-stagger>
      {copy.demo.gallery.map((item) => (
        <figure class="reveal">
          <div class="frame-light">
            <img src={item.shot} alt={item.caption} width="1920" height="1080" loading="lazy" />
          </div>
          <figcaption class="text-text-3 text-sm mt-2.5">{item.caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
