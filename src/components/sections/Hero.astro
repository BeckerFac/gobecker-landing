---
import { copy, REGISTER_URL, WA_URL } from '../../content/copy';
---

<section
  class="bg-ink pt-32 pb-20 sm:pt-40 sm:pb-24 px-6 relative overflow-hidden"
  style="background-image: radial-gradient(ellipse 60% 45% at 50% 78%, rgba(41, 82, 227, 0.14), transparent 70%);"
>
  <div class="max-w-6xl mx-auto text-center relative">
    <p class="hero-seq hero-seq-1 inline-flex items-center gap-2 border border-white/12 rounded-full px-4 py-1.5 font-mono text-[0.8125rem] text-inv-2 mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-brand inline-block"></span>
      {copy.hero.badge}
    </p>

    <h1 class="hero-seq hero-seq-2 display text-inv mx-auto max-w-4xl" style="font-size: clamp(2.625rem, 6.5vw, 4.75rem);">
      {copy.hero.headline}
    </h1>

    <p class="hero-seq hero-seq-3 text-inv-2 text-lg sm:text-xl max-w-2xl mx-auto mt-6 leading-relaxed">
      {copy.hero.subheadline}
    </p>

    <div class="hero-seq hero-seq-4 flex flex-col sm:flex-row items-center justify-center gap-3.5 mt-9">
      <a href={REGISTER_URL} class="btn btn-primary w-full sm:w-auto !text-[1.0625rem] !px-7 !py-4">{copy.hero.cta_primary}</a>
      <a href={WA_URL} target="_blank" rel="noopener" class="btn btn-ghost-dark w-full sm:w-auto !text-[1.0625rem] !px-7 !py-4">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2a9.9 9.9 0 0 0-8.44 15.1L2 22l5.05-1.55A9.9 9.9 0 1 0 12.04 2Zm5.8 14.06c-.24.68-1.4 1.3-1.93 1.35-.52.05-1.01.24-3.4-.7-2.87-1.14-4.68-4.06-4.82-4.25-.14-.19-1.15-1.53-1.15-2.92s.73-2.07.99-2.35c.26-.28.56-.35.75-.35h.54c.17 0 .4-.06.63.48.24.56.8 1.95.87 2.09.07.14.12.31.02.5-.09.19-.14.3-.28.47l-.42.5c-.14.14-.29.3-.12.58.16.28.73 1.2 1.57 1.95 1.08.96 1.99 1.26 2.27 1.4.28.14.45.12.61-.07.17-.19.7-.82.89-1.1.19-.28.38-.23.63-.14.26.1 1.64.78 1.92.92.28.14.47.21.54.32.07.12.07.68-.17 1.32Z"/></svg>
        {copy.hero.cta_secondary}
      </a>
    </div>

    <p class="hero-seq hero-seq-4 font-mono text-[0.8125rem] text-inv-2 mt-6">{copy.hero.micro}</p>

    <div class="hero-seq hero-seq-5 frame max-w-5xl mx-auto mt-14">
      <div class="frame-bar" aria-hidden="true"><span></span><span></span><span></span></div>
      <img
        src="/shots/ventas-lista.webp"
        alt="Pedidos y ventas en GoBecker: ventas POS con cliente, items, total y estado de pago"
        width="1920"
        height="1080"
        fetchpriority="high"
      />
    </div>
  </div>
</section>
