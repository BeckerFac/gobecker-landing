---
import { copy, REGISTER_URL, WA_URL } from '../../content/copy';
---

<section id="precio" class="bg-bg section-pad">
  <div class="max-w-6xl mx-auto">
    <div class="reveal text-center max-w-2xl mx-auto">
      <p class="kicker mb-3">{copy.pricing.kicker}</p>
      <h2 class="display text-4xl sm:text-5xl">{copy.pricing.title}</h2>
      <p class="text-text-2 text-lg mt-4">{copy.pricing.sub}</p>
    </div>

    <div class="reveal max-w-xl mx-auto mt-12 bg-coal rounded-3xl p-8 sm:p-11 text-inv relative overflow-hidden"
      style="background-image: radial-gradient(ellipse 70% 50% at 50% -10%, rgba(12, 138, 77, 0.25), transparent 70%);">
      <p class="num text-[0.8125rem] uppercase tracking-[0.12em] text-inv-2">{copy.pricing.plan_name}</p>
      <p class="mt-3 flex items-baseline gap-2">
        <span class="num font-bold text-inv" style="font-size: clamp(3.25rem, 7vw, 4.5rem); letter-spacing: -0.02em;">{copy.pricing.price_line}</span>
        <span class="num text-inv-2 text-lg">/mes</span>
      </p>
      <p class="text-inv-2 text-[0.9375rem] mt-1">{copy.pricing.trial_line}</p>

      <ul class="mt-8 grid sm:grid-cols-2 gap-x-6 gap-y-3">
        {copy.pricing.includes.map((item) => (
          <li class="flex items-start gap-2.5 text-[0.9375rem] text-inv leading-snug">
            <svg class="mt-1 flex-none" width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13.5 4.5 6.4 11.6 2.5 7.7" stroke="#3ECF8E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {item}
          </li>
        ))}
      </ul>

      <a href={REGISTER_URL} data-meta="lead" data-meta-name="Pricing - Empezar gratis" class="btn btn-primary w-full mt-9 !py-4 !text-[1.0625rem]">{copy.pricing.cta}</a>
      <p class="num text-[0.8125rem] text-inv-2 text-center mt-4">{copy.pricing.micro}</p>
    </div>

    <p class="reveal text-center text-text-2 mt-8">
      ¿Querés que te lo cuente una persona?
      <a href={WA_URL} target="_blank" rel="noopener" data-meta="contact" data-meta-name="Pricing - WhatsApp" class="text-green font-semibold hover:underline">Escribinos por WhatsApp</a>
    </p>
  </div>
</section>
