---
import { copy } from '../../content/copy';
---

<section id="funciones" class="bg-bg section-pad">
  <div class="max-w-6xl mx-auto">
    <div class="reveal max-w-2xl">
      <p class="kicker mb-3">Funciones</p>
      <h2 class="display text-4xl sm:text-5xl">Lo que hace, sin vueltas</h2>
    </div>

    <div class="grid md:grid-cols-6 gap-5 mt-12" data-stagger>
      {copy.features.map((f) => (
        <div
          class={`reveal bento-cell ${f.span === 'lg' ? 'md:col-span-4' : 'md:col-span-2'}`}
          style={`--cell-accent: ${f.accent}`}
        >
          <p class="num text-[0.8125rem] uppercase tracking-[0.1em] font-medium mb-2.5" style={`color: ${f.accent}`}>{f.kicker}</p>
          <h3 class="display text-2xl sm:text-[1.75rem]">{f.title}</h3>
          <p class="text-text-2 mt-3 mb-4 leading-relaxed text-[0.9375rem]">{f.body}</p>
          {f.shot && (
            <div class="frame-inner">
              <img src={f.shot} alt={f.title} width="1920" height="1080" loading="lazy" />
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
