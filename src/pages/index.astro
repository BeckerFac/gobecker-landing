    <!-- ===== SCRIPTS (minimal - most is in React components) ===== -->
    <script>
      // Nav scroll
      const nav = document.getElementById('nav');
      window.addEventListener('scroll', () => { nav.style.borderBottomColor = window.scrollY > 50 ? 'rgba(99,102,241,0.3)' : 'rgba(99,102,241,0.15)'; }, { passive: true });

      // Smooth scroll
      document.querySelectorAll('a[href^="#"]').forEach((a) => { a.addEventListener('click', function(e) { e.preventDefault(); const t = document.querySelector(this.getAttribute('href')); if (t) t.scrollIntoView({ behavior: 'smooth', block: 'start' }); }); });

      // Mobile menu
      const mt = document.getElementById('mobile-toggle'), mm = document.getElementById('mobile-menu');
      mt.addEventListener('click', () => { mm.classList.toggle('hidden'); mt.querySelectorAll('.hamburger-line').forEach(l => l.classList.toggle('active')); });
      document.querySelectorAll('.mobile-link').forEach(l => { l.addEventListener('click', () => mm.classList.add('hidden')); });

      // Video overlay
      const v = document.getElementById('demo-video'), o = document.getElementById('play-overlay');
      if (o && v) { o.addEventListener('click', () => { v.play(); o.style.opacity='0'; o.style.pointerEvents='none'; }); v.addEventListener('play', () => { o.style.opacity='0'; o.style.pointerEvents='none'; }); v.addEventListener('pause', () => { if(v.currentTime>0&&!v.ended){o.style.opacity='1';o.style.pointerEvents='auto';}}); v.addEventListener('ended', () => { o.style.opacity='1'; o.style.pointerEvents='auto'; }); }

      // Sticky CTA mobile
      const sc = document.getElementById('sticky-cta');
      const so = new IntersectionObserver((e) => { e.forEach(en => { if(en.isIntersecting) sc.classList.add('hidden'); else sc.classList.remove('hidden'); }); }, { threshold: 0 });
      const hs = document.querySelector('section'); if(hs) so.observe(hs);

      // Shiny button mouse tracker
      document.querySelectorAll('.shiny-btn').forEach(btn => { btn.addEventListener('mousemove', (e) => { const r = btn.getBoundingClientRect(); btn.style.setProperty('--shine-x', `${e.clientX - r.left}px`); btn.style.setProperty('--shine-y', `${e.clientY - r.top}px`); }); });
    </script>

