---
import '../styles/global.css';
import { copy } from '../content/copy';
import Nav from '../components/sections/Nav.astro';
import Hero from '../components/sections/Hero.astro';
import Features from '../components/sections/Features.astro';
import ParaQuien from '../components/sections/ParaQuien.astro';
import Pricing from '../components/sections/Pricing.astro';
import Faq from '../components/sections/Faq.astro';
import CtaFinal from '../components/sections/CtaFinal.astro';
import Footer from '../components/sections/Footer.astro';
import StickyCta from '../components/sections/StickyCta.astro';
import MetaPixel from '../components/MetaPixel.astro';
import MetaEvents from '../components/MetaEvents.astro';

const SITE = 'https://gobecker.com.ar';
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <MetaPixel />
    <title>{copy.meta_seo.title}</title>
    <meta name="description" content={copy.meta_seo.description} />
    <link rel="canonical" href={SITE} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#101315" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE} />
    <meta property="og:title" content={copy.meta_seo.title} />
    <meta property="og:description" content={copy.meta_seo.description} />
    <meta property="og:image" content={`${SITE}/og.jpg`} />
    <meta property="og:locale" content="es_AR" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preload" href="/fonts/clash-display-600.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/general-sans-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/general-sans-600.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/space-grotesk-500.woff2" as="font" type="font/woff2" crossorigin />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'SoftwareApplication',
        name: 'GoBecker',
        applicationCategory: 'BusinessApplication',
        operatingSystem: 'Web',
        description: copy.meta_seo.description,
        url: SITE,
        inLanguage: 'es-AR',
        offers: {
          '@type': 'Offer',
          price: '70',
          priceCurrency: 'USD',
          description: 'Plan único mensual, todo incluido. 7 días de prueba gratis sin tarjeta.',
        },
      })}
    />
  </head>
  <body class="bg-bg">
    <Nav />
    <main>
      <Hero />
      <Features />
      <ParaQuien />
      <Pricing />
      <Faq />
      <CtaFinal />
    </main>
    <Footer />
    <StickyCta />
    <MetaEvents />

    <script>
      // Entrada orquestada del hero
      requestAnimationFrame(() => document.body.classList.add('loaded'));

      // Scroll reveal (solo transform + opacity)
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const reveals = document.querySelectorAll('.reveal');
      if (reduced || !('IntersectionObserver' in window)) {
        reveals.forEach((el) => el.classList.add('in'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.08 }
        );
        reveals.forEach((el) => io.observe(el));
      }

      // Nav con fondo al scrollear + sticky CTA mobile tras pasar el hero
      const nav = document.getElementById('nav');
      const sticky = document.getElementById('sticky-cta');
      const onScroll = () => {
        nav?.classList.toggle('scrolled', window.scrollY > 24);
        sticky?.classList.toggle('show', window.scrollY > window.innerHeight * 0.9);
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      // Menu mobile
      const menuBtn = document.getElementById('menu-btn');
      const menuPanel = document.getElementById('menu-panel');
      menuBtn?.addEventListener('click', () => {
        const hidden = menuPanel?.classList.toggle('hidden');
        menuBtn.setAttribute('aria-expanded', String(!hidden));
        nav?.classList.add('scrolled');
      });
      menuPanel?.querySelectorAll('.menu-link').forEach((link) =>
        link.addEventListener('click', () => menuPanel.classList.add('hidden'))
      );

      // Video slots: reproducir el mp4 si existe
      document.querySelectorAll<HTMLElement>('.video-slot').forEach((slot) => {
        const activate = async () => {
          const src = slot.dataset.videoSrc;
          if (!src || slot.dataset.state) return;
          slot.dataset.state = 'checking';
          let ok = false;
          try {
            const res = await fetch(src, { method: 'HEAD' });
            ok = res.ok && (res.headers.get('content-type') ?? '').includes('video');
          } catch {
            ok = false;
          }
          if (ok) {
            const video = document.createElement('video');
            video.src = src;
            video.controls = true;
            video.autoplay = true;
            video.playsInline = true;
            video.style.display = 'block';
            video.style.width = '100%';
            slot.replaceChildren(video);
            slot.style.cursor = 'default';
          } else {
            slot.dataset.state = 'soon';
            const badge = slot.querySelector('.play-badge');
            if (badge) {
              badge.innerHTML =
                '<span style="background:rgba(255,255,255,0.95);color:#1B2228;font-weight:600;font-size:0.9375rem;padding:0.6rem 1.1rem;border-radius:99px;">El video llega muy pronto</span>';
            }
            setTimeout(() => {
              delete slot.dataset.state;
            }, 2500);
          }
        };
        slot.addEventListener('click', activate);
        slot.addEventListener('keydown', (e) => {
          if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
            e.preventDefault();
            activate();
          }
        });
      });
    </script>
  </body>
</html>
